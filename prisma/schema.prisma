generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  HR
  MANAGER
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EARLY_LEAVE
  HALF_DAY
  MISSING_PUNCH
  OFF
  LEAVE
}

enum LogSource {
  DEVICE
  FACE
  MANUAL
  MOCK
}

enum VerifyType {
  FINGERPRINT
  FACE
  CARD
  PASSWORD
  MANUAL
}

enum DeviceVendor {
  ZKTECO
  HIKVISION
  ANVIZ
  SUPREMA
  MOCK
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          Int              @id @default(autoincrement())
  code        String           @unique
  name        String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String
  role         UserRole
  roleId       Int?
  roleRef      Role?     @relation(fields: [roleId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Department {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  employees   Employee[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Shift {
  id            Int        @id @default(autoincrement())
  name          String
  startTime     String
  endTime       String
  lateAfterMin  Int        @default(0)
  earlyOutMin   Int        @default(0)
  employees     Employee[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Employee {
  id              Int                @id @default(autoincrement())
  employeeCode    String             @unique
  firstName       String
  lastName        String
  gender          String?
  phone           String?
  email           String?
  photo           String?
  faceDescriptor  String?
  deviceUserId    String?            @unique
  status          EmployeeStatus     @default(ACTIVE)
  departmentId    Int?
  shiftId         Int?
  department      Department?        @relation(fields: [departmentId], references: [id])
  shift           Shift?             @relation(fields: [shiftId], references: [id])
  logs            AttendanceLog[]
  records         AttendanceRecord[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Device {
  id             Int          @id @default(autoincrement())
  name           String
  vendor         DeviceVendor @default(MOCK)
  ipAddress      String?
  port           Int?
  serialNumber   String?
  deviceType     String
  location       String?
  username       String?
  password       String?
  apiKey         String?
  apiSecret      String?
  baseUrl        String?
  webhookSecret  String?
  siteCode       String?
  isActive       Boolean      @default(true)
  lastSyncAt     DateTime?
  configJson     Json?
  logs           AttendanceLog[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model AttendanceLog {
  id            Int               @id @default(autoincrement())
  employeeId    Int?
  deviceId      Int?
  deviceUserId  String?
  logTime       DateTime
  verifyType    VerifyType        @default(MANUAL)
  source        LogSource         @default(MANUAL)
  direction     String?
  rawData       Json?
  employee      Employee?         @relation(fields: [employeeId], references: [id])
  device        Device?           @relation(fields: [deviceId], references: [id])
  createdAt     DateTime          @default(now())
}

model AttendanceRecord {
  id               Int               @id @default(autoincrement())
  employeeId       Int
  attendanceDate   DateTime
  checkIn          DateTime?
  checkOut         DateTime?
  lateMinutes      Int               @default(0)
  earlyLeaveMin    Int               @default(0)
  overtimeMinutes  Int               @default(0)
  workedMinutes    Int               @default(0)
  status           AttendanceStatus  @default(PRESENT)
  remark           String?
  employee         Employee          @relation(fields: [employeeId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([employeeId, attendanceDate])
}

model LeaveRequest {
  id            Int       @id @default(autoincrement())
  employeeId    Int
  fromDate      DateTime
  toDate        DateTime
  leaveType     String
  reason        String?
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
